# Copy to .env.local and fill in. Do not commit real secrets.

# --- Redis (Upstash) ---
KV_URL=""
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
KV_REST_API_READ_ONLY_TOKEN=""
REDIS_URL=""

# --- Cron ---
# Bearer token required to call GET /api/cron (expired-file cleanup).
CRON_SECRET=""

# --- Upload limits ---
# Must use the NEXT_PUBLIC_ prefix so the browser can read them too.
NEXT_PUBLIC_MAX_FILE_COUNT="10"
NEXT_PUBLIC_MAX_TOTAL_SIZE_MB="50"

# --- Storage backend ---
# "vercel" (default) or "r2".
STORAGE_PROVIDER="vercel"

# Common: object key prefix used by both backends.
UPLOAD_PATH="paaster"

# Vercel Blob (required when STORAGE_PROVIDER=vercel).
BLOB_READ_WRITE_TOKEN=""

# Cloudflare R2 (required when STORAGE_PROVIDER=r2).
# The bucket must allow public read access; R2_PUBLIC_URL is the public bucket
# URL (https://pub-xxxx.r2.dev) or a custom domain bound to the bucket.
# R2_PUBLIC_URL must map to the bucket root with NO path segment (e.g.
# https://files.example.com, not https://files.example.com/cdn) — file cleanup
# derives the object key from the URL path and would target the wrong key
# otherwise, silently leaving expired files in the bucket.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"
